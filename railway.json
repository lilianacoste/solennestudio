{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack pnpm install --frozen-lockfile --prefer-offline && corepack pnpm run build"
  },
  "deploy": {
    "startCommand": "corepack pnpm run serve",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
